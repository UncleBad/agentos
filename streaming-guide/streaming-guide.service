[Unit]
Description=Streaming Guide — broadcast + streaming listings
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=omar
Group=omar
WorkingDirectory=/home/omar/agentos/streaming-guide
EnvironmentFile=/home/omar/agentos/streaming-guide/.env
ExecStart=/usr/bin/python3 /home/omar/agentos/streaming-guide/server.py
Restart=always
RestartSec=5

NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/omar/agentos/streaming-guide/data
PrivateTmp=true

[Install]
WantedBy=multi-user.target