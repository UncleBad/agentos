# freellmapi runtime config — bind to loopback only.
# Copy to .env and fill in. The .env file is gitignored.

# --- Network ---
# CRITICAL: bind to loopback only. freellmapi's auth model assumes
# the gateway is single-user on localhost. Do NOT change without
# a security review (see wiki/freellmapi-spike.md).
HOST=127.0.0.1
PORT=3001

# --- Storage ---
# Where the SQLite DB + dashboard config live.
# (Back this up if you invest time adding provider keys.)
# Note: the app hardcodes the DB path to server/data/freeapi.db
# relative to its CWD. DATA_DIR is not used by the app.

# --- Encryption ---
# 32-byte hex, AES-256-GCM key for at-rest provider keys.
# The app reads ENCRYPTION_KEY directly (not a file path).
# Generate with: openssl rand -hex 32
# CRITICAL: lose this key = all stored provider keys become unreadable.
# Back it up somewhere safe (separate machine, password manager, etc.)
ENCRYPTION_KEY=

# --- Auth ---
# Optional: pre-set the admin user. If unset, the dashboard's first-run
# flow at http://127.0.0.1:3001 will prompt to create one.
# ADMIN_EMAIL=captain@remotebox
# ADMIN_PASSWORD=<use a strong password + password manager>

# --- Optional: catalog refresh ---
# Free tier = monthly snapshot of the upstream model catalog.
# Premium ($19/yr or $49 lifetime) = live feed. Skip for now.
# FREELLMAPI_PREMIUM_KEY=

# --- Logging ---
LOG_LEVEL=info
